# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@localhost:5432/buddy_ai
REDIS_URL=redis://localhost:6379/0

# ==================== SECURITY ====================
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ==================== AI MODELS ====================
# Local AI (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=mistral

# Cloud AI (Optional fallback)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
QWEN_API_KEY=

# ==================== EMAIL ====================
# Gmail integration
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ==================== MESSAGING ====================
# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Telegram
TELEGRAM_BOT_TOKEN=

# ==================== API KEYS ====================
# Search & Research
SERPAPI_API_KEY=
NEWSAPI_KEY=

# ==================== FRONTEND ====================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ==================== DEPLOYMENT ====================
DEPLOYMENT_ENVIRONMENT=local
DOMAIN=localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== MONITORING ====================
SENTRY_DSN=
