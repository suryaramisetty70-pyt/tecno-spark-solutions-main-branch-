# Database Configuration
DATABASE_URL=postgresql+asyncpg://buddy_user:buddy_password@localhost:5432/buddy_ai_db
SQL_ECHO=false

# Environment
ENV=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# JWT/Authentication
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Models (Free Cloud APIs)
GEMINI_API_KEY=
GROQ_API_KEY=
DEFAULT_AI_PROVIDER=gemini # gemini or groq
DEFAULT_AI_MODEL=gemini-1.5-flash # gemini-1.5-flash or llama3-8b-8192

# Third-Party Integrations
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URL=http://localhost:8000/api/v1/integrations/gmail/callback

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

TELEGRAM_BOT_TOKEN=

# Vector Database (ChromaDB)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Graph Database (Neo4j)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/buddy_api.log

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Sentry (Error Tracking - Optional)
SENTRY_DSN=

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# Feature Flags
ENABLE_WORKFLOWS=true
ENABLE_INTEGRATIONS=true
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOG=true
