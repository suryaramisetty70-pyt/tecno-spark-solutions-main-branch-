# ==================== ENVIRONMENT: PRODUCTION ====================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ==================== SERVER CONFIGURATION ====================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ==================== DATABASE (PostgreSQL + AsyncPG) ====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/buddy_ai
SQL_ECHO=false

# ==================== CACHING (Redis) ====================
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ==================== SECURITY - MUST CHANGE IN PRODUCTION ====================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-32-character-random-string-in-production
ENCRYPTION_KEY=change-this-to-44-character-fernet-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production

# ==================== JWT TOKEN CONFIGURATION ====================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== CORS & SECURITY ====================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=*
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ==================== VECTOR DATABASE (ChromaDB) ====================
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_COLLECTION=agent_embeddings

# ==================== LOCAL AI MODELS (FREE - OLLAMA) ====================
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_LOCAL_MODEL=mistral
# Available free models: mistral, llama2, neural-chat, starling-lm, falcon, orca-mini

# ==================== GRAPH DATABASE (Neo4j - Optional) ====================
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ==================== MONITORING & LOGGING ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin
LOG_FILE=/app/logs/buddy_api.log
LOG_RETENTION_DAYS=30

# ==================== FREE EMAIL SERVICE (BREVO) ====================
# Get free API key at: https://www.brevo.com/
# FREE TIER: 300 emails per day
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=Tecno Spark Buddy AI

# ==================== FREE NOTIFICATIONS (NTFY) ====================
# Free push notifications - no account needed
# More info: https://ntfy.sh/
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=buddy-ai-notifications

# ==================== FREE MESSAGING (TELEGRAM) ====================
# Setup bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ==================== MULTI-TENANCY CONFIGURATION ====================
# Organization limits
ORG_MAX_USERS_FREE=5
ORG_MAX_USERS_PRO=100
ORG_MAX_AGENTS_FREE=50
ORG_MAX_AGENTS_PRO=500

# ==================== AGENT CONFIGURATION ====================
MAX_AGENTS_PER_REQUEST=10
AGENT_EXECUTION_TIMEOUT_SECONDS=300
AGENT_RETRY_ATTEMPTS=3

# ==================== RATE LIMITING ====================
# Per minute limits by role
RATE_LIMIT_ADMIN=10000
RATE_LIMIT_MANAGER=1000
RATE_LIMIT_MEMBER=100
RATE_LIMIT_GUEST=50

# ==================== AUDIT & COMPLIANCE ====================
AUDIT_LOG_RETENTION_DAYS=365
ENABLE_AUDIT_LOG=true
ENABLE_DATA_ENCRYPTION=true
GDPR_ENABLED=true
HIPAA_ENABLED=true

# ==================== FEATURE FLAGS ====================
ENABLE_WORKFLOWS=true
ENABLE_INTEGRATIONS=true
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOG=true
ENABLE_MULTI_TENANCY=true
ENABLE_RBAC=true
ENABLE_ENCRYPTION=true

# ==================== ANALYTICS ====================
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# ==================== PAID SERVICES - ALL REPLACED WITH FREE ALTERNATIVES ====================
# ❌ TWILIO (paid) → ✅ NTFY (free)
# ❌ SENDGRID (paid) → ✅ BREVO (free: 300/day)
# ❌ MAILCHIMP (paid) → ✅ BREVO (free: 300/day)
# ❌ SENTRY (paid) → ✅ PROMETHEUS + ELK (free)
# ❌ DATADOG (paid) → ✅ PROMETHEUS + GRAFANA (free)
# ❌ OPENAI (paid) → ✅ OLLAMA LOCAL (free)
# ❌ DEEPSEEK (paid) → ✅ OLLAMA LOCAL (free)
# ❌ AWS S3 (paid) → ✅ Local storage or MinIO (free)
# ALL SERVICES = FREE & OPEN-SOURCE ✅

# ==================== DATABASE BACKUP (Optional) ====================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=7

# ==================== DEPLOYMENT ====================
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_CONNECTIONS=1000
